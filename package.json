{
  "name": "gap-credito-backend",
  "version": "1.0.0",
  "description": "Backend API para GAP Corporativo - Gestion de Credito por Estacion",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset --force",
    "postinstall": "npx prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  },
  "keywords": [
    "gap",
    "credito",
    "estaciones"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=22.12.0"
  }
}
