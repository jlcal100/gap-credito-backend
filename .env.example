# Base de datos PostgreSQL (Railway la provee automaticamente)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT Secrets (generar strings aleatorios largos)
JWT_SECRET="cambiar-por-string-aleatorio-largo-64-chars-minimo"
JWT_REFRESH_SECRET="cambiar-por-otro-string-aleatorio-largo-diferente"

# Puerto (Railway lo asigna automaticamente)
PORT=3000

# Entorno
NODE_ENV=development
